ANTHROPIC_API_KEY=sk-ant-your-key-here
PORT=8000

# Optional: path to Instagram cookies file for yt-dlp authentication
# Export using "Get cookies.txt LOCALLY" browser extension from a logged-in Instagram session
# Cookies expire ~30 days and must be refreshed manually
INSTAGRAM_COOKIES_PATH=./cookies.txt

# Max thumbnail width in pixels before sending to Claude (controls cost)
THUMBNAIL_MAX_WIDTH=1024

# PostgreSQL — from Railway plugin (auto-injected in Railway, set manually for local dev)
DATABASE_URL=postgresql://user:password@localhost:5432/recipewizard

# Google OAuth — use the Web/Server client ID from Google Cloud Console
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-random-string-at-least-64-chars
JWT_EXPIRES_IN=30d
